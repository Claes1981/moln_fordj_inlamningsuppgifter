<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudSoft Recruitment Portal</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-brand">
                <a asp-controller="Home" asp-action="Index">CloudSoft Recruitment</a>
            </div>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Home</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("Administrator"))
                    {
                        <a asp-controller="JobPostings" asp-action="Index">Manage Job Postings</a>
                    }
                    <span class="user-info">Welcome, @User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                        <button type="submit">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login">Login</a>
                }
            </div>
        </nav>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <footer>
        <div class="container">
            <p>&copy; @DateTime.Now.Year - CloudSoft Recruitment Portal</p>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
