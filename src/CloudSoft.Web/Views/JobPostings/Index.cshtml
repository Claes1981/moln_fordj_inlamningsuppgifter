@model IEnumerable<CloudSoft.Domain.JobPosting>

@{
    ViewData["Title"] = "Manage Job Postings";
}

<h1>Job Postings</h1>

<p>
    <a asp-action="Create" class="btn">Create New Job Posting</a>
</p>

@if (!Model.Any())
{
    <p>No job postings found.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Location</th>
                <th>Status</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Location</td>
                    <td>@item.Status</td>
                    <td>@(item.IsActive ? "Yes" : "No")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        @if (item.Status == CloudSoft.Domain.JobPostingStatus.Draft)
                        {
                            <form asp-action="Publish" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit">Publish</button>
                            </form>
                        }
                        @if (item.Status == CloudSoft.Domain.JobPostingStatus.Published)
                        {
                            <form asp-action="Close" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit">Close</button>
                            </form>
                        }
                        @if (item.Status == CloudSoft.Domain.JobPostingStatus.Draft)
                        {
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" onclick="return confirm('Are you sure you want to delete this job posting?');">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
